# Caddyfile d'EcoShield-Minimal — FrankenPHP en mode Worker pour AWS Lambda.

{
	# Mode Worker FrankenPHP : l'application est amorcée UNE SEULE FOIS puis
	# réside en mémoire (conteneur + routes compilés). « num 1 » force un unique
	# worker, optimal sur les environnements serverless mono-vCPU (AWS Lambda).
	frankenphp {
		worker {
			file /app/public/index.php
			num 1
		}
	}

	# AWS Lambda assure lui-même la terminaison TLS en amont : on désactive
	# l'HTTPS automatique de Caddy et on sert en clair sur le port local.
	auto_https off
}

# Le AWS Lambda Web Adapter (LWA) transmet chaque évènement Lambda à ce port
# local : on écoute donc obligatoirement sur le port 8080.
:8080 {
	root * /app/public
	encode zstd gzip

	php_server {
		# Point d'entrée unique pour les URLs ne correspondant pas à un fichier.
		resolve_root_symlink
	}

	# Sert les éventuels fichiers statiques (images, CSS, JS).
	file_server
}
